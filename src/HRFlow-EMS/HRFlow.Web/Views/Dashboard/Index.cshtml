@model HRFlow.Business.DTOs.Dashboard.DashboardDto
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}


<div class="row" style="padding-top:10px;">

    <div class="col-lg-3 col-md-6">
        <a asp-controller="Employee"
           asp-action="Index"
           class="dashboard-card-link">
            <div class="info-box">
                <span class="info-box-icon text-bg-primary shadow-sm">
                    <i class="bi bi-people-fill"></i>
                </span>
                <div class="info-box-content">
                    <span class="info-box-text">Toplam Personel</span>
                    <span class="info-box-number">@Model.EmployeeCount</span>
                    <small class="text-body-secondary">Aktif çalışan sayısı</small>
                </div>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-6">
        <a asp-controller="Department"
           asp-action="Index"
           class="dashboard-card-link">
            <div class="info-box">
                <span class="info-box-icon text-bg-success shadow-sm">
                    <i class="bi bi-building"></i>
                </span>

                <div class="info-box-content">
                    <span class="info-box-text">Departman</span>
                    <span class="info-box-number">@Model.DepartmentCount</span>
                    <small class="text-body-secondary">Tanımlı departman</small>
                </div>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-6">
        <a asp-controller="Position"
           asp-action="Index"
           class="dashboard-card-link">
            <div class="info-box">
                <span class="info-box-icon text-bg-warning shadow-sm">
                    <i class="bi bi-briefcase-fill"></i>
                </span>

                <div class="info-box-content">
                    <span class="info-box-text">Pozisyon</span>
                    <span class="info-box-number">@Model.PositionCount</span>
                    <small class="text-body-secondary">Tanımlı pozisyon</small>
                </div>
            </div>
        </a>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="info-box">
            <span class="info-box-icon text-bg-danger shadow-sm">
                <i class="bi bi-calendar-check-fill"></i>
            </span>

            <div class="info-box-content">
                <span class="info-box-text">İzinli Personel</span>
                <span class="info-box-number">@Model.LeaveCount</span>
                <small class="text-body-secondary">Bugün izinli</small>
            </div>
        </div>
    </div>

</div>

<div class="row mt-3 align-items-stretch">

    <!-- Son Eklenen Personeller -->
    <div class="col-lg-7 d-flex">

        <div class="card flex-fill">

            <div class="card-header">
                <h3 class="card-title fw-semibold">
                    <i class="bi bi-person-lines-fill text-success me-2"></i>
                    Son Eklenen Personeller
                </h3>

                <div class="card-tools">
                    <a asp-controller="Employee"
                       asp-action="Index"
                       class="btn btn-sm btn-outline-primary">
                        Tümünü Gör
                    </a>
                </div>
            </div>

            <div class="card-body p-0">

                <div class="list-group list-group-flush">

                    @if (Model.LastEmployees.Any())
                    {
                        @foreach (var employee in Model.LastEmployees)
                        {
                            <a asp-controller="Employee"
                               asp-action="Edit"
                               asp-route-id="@employee.Id"
                               class="list-group-item list-group-item-action">

                                <div class="d-flex justify-content-between align-items-center">

                                    <div>

                                        <h6 class="mb-1 fw-semibold">
                                            <i class="bi bi-person-circle me-2"></i>
                                            @employee.FullName
                                        </h6>

                                        <div class="mt-2">

                                            <div class="small text-body-secondary">
                                                <i class="bi bi-briefcase-fill me-2"></i>
                                                @employee.PositionName
                                            </div>

                                            <div class="small text-body-secondary">
                                                <i class="bi bi-building me-2"></i>
                                                @employee.DepartmentName
                                            </div>

                                        </div>

                                    </div>

                                </div>

                            </a>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">

                            <i class="bi bi-people display-4 text-body-secondary"></i>

                            <h5 class="mt-3">
                                Henüz personel bulunmuyor
                            </h5>

                            <p class="text-body-secondary mb-4">
                                Sisteme ilk personeli ekleyerek başlayabilirsiniz.
                            </p>

                            <a asp-controller="Employee"
                               asp-action="Create"
                               class="btn btn-primary">

                                <i class="bi bi-plus-circle me-2"></i>

                                Personel Ekle

                            </a>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

    <!-- Sağ Taraf -->
    <div class="col-lg-5 d-flex">

        <div class="card flex-fill">

            <div class="card-header">
                <h3 class="card-title fw-semibold">
                    <i class="bi bi-pie-chart-fill text-primary me-2"></i>
                    Departman Dağılımı
                </h3>
            </div>

            <div class="card-body text-center">

                <div class="card-body">

                    <div class="card-body">

                        <div style="height:320px;">

                            <canvas id="departmentChart"></canvas>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>
@section Scripts
{
    <script>

        const labels = [
        @foreach (var item in Model.DepartmentChart)
        {
                @Html.Raw($"'{item.DepartmentName}',")
        }
        ];

        const values = [
        @foreach (var item in Model.DepartmentChart)
        {
                @Html.Raw($"{item.EmployeeCount},")
        }
        ];

        const ctx = document.getElementById('departmentChart');

        const textColor = getComputedStyle(document.documentElement)
        .getPropertyValue('--bs-body-color')
        .trim();
        new Chart(ctx, {

            type: 'doughnut',

            data: {

                labels: labels,

                       datasets: [{

            data: values,

            borderWidth: 1,

            borderColor: '#2b3035',

            backgroundColor: [

                '#0d6efd',
                '#20c997',
                '#ffc107',
                '#dc3545',
                '#6f42c1',
                '#fd7e14',
                '#0dcaf0',
                '#198754',
                '#6610f2',
                '#adb5bd'

            ]

        }]

            },

              options: {

            responsive: true,

            maintainAspectRatio: false,

            plugins: {

                legend: {

                    position: 'bottom',

                    labels: {

                        color: textColor,

                        usePointStyle: true,

                        pointStyle: 'circle',

                        padding: 20,

                        font: {

                            size: 13,

                            weight: '500'

                        }

                    }

                }

            }

        }

        });

    </script>
}