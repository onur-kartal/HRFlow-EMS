@model HRFlow.Web.Models.Position.PositionEditViewModel

<h2>Pozisyonu Düzenle</h2>

<form asp-action="Edit" method="post">
    <input asp-for="Position.Id" type="hidden" />
    <div class="mb-3">
        <label>Pozisyon Adı</label>
        <input asp-for="Position.Name" class="form-control" />
        <span asp-validation-for="Position.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Pozisyon açıklaması</label>
        <input asp-for="Position.Description" class="form-control" />
        <span asp-validation-for="Position.Description" class="text-danger"></span>
    </div>

    <button class="btn btn-primary">
        Kaydet
    </button>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}