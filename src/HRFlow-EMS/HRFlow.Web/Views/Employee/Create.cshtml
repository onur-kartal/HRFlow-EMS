@model HRFlow.Web.Models.Employee.EmployeeCreateViewModel

<h2>Yeni Çalışan</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label>Ad</label>
        <input asp-for="Employee.FirstName" class="form-control" />
        <span asp-validation-for="Employee.FirstName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Soyad</label>
        <input asp-for="Employee.LastName" class="form-control" />
        <span asp-validation-for="Employee.LastName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Employee.Email" class="form-control" />
        <span asp-validation-for="Employee.Email" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Departman</label>
        <select asp-for="Employee.DepartmentId"
                asp-items="Model.Departments"
                class="form-select">
            <option value="0">Seçiniz</option>
        </select>
        <span asp-validation-for="Employee.DepartmentId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label>Pozisyon</label>
        <select asp-for="Employee.PositionId"
                asp-items="Model.Positions"
                class="form-select">
            <option value="0">Seçiniz</option>
        </select>
        <span asp-validation-for="Employee.PositionId" class="text-danger"></span>
    </div>

    <button class="btn btn-primary">
        Kaydet
    </button>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}