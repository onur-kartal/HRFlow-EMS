@model List<HRFlow.Business.DTOs.Employee.EmployeeListDto>

<h2>Çalışanlar</h2>

<table class="table">
    <thead>
        <tr>
            <th>Ad Soyad</th>
            <th>Departman</th>
            <th>Pozisyon</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.DepartmentName</td>
                <td>@item.PositionName</td>
                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Düzenle
                    </a>

                    <form asp-action="Delete"
                          asp-route-id="@item.Id"
                          method="post"
                          style="display:inline;"
                          class="delete-form">

                        <button type="submit"
                                class="btn btn-danger btn-sm">
                            Sil
                        </button>

                    </form>
                </td>
            </tr>
        }

    </tbody>
</table>
@section Scripts
{
    <script>
        document.querySelectorAll(".delete-form").forEach(form => {

            form.addEventListener("submit", function (e) {

                e.preventDefault();

                Swal.fire({
                    title: "Emin misiniz?",
                    text: "Bu çalışan silinecek.",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Evet, Sil",
                    cancelButtonText: "İptal",
                    reverseButtons: true
                }).then((result) => {

                    if (result.isConfirmed) {
                        form.submit();
                    }

                });

            });

        });
    </script>
}